  m_TableData:
  - m_Id: 10577969152
    m_Localized: "\u0411\u0435\u0440\u0456\u043B\u0433\u0435\u043D \u043C\u044B\u0441\u0430\u043B\u0434\u044B
      \u043C\u04B1\u049B\u0438\u044F\u0442 \u0442\u044B\u04A3\u0434\u0430\u043F,
      \u0441\u04B1\u0440\u0430\u049B\u0442\u0430\u0440\u0493\u0430 \u0434\u04B1\u0440\u044B\u0441
      \u0436\u0430\u0443\u0430\u043F \u0431\u0435\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 286907105280
    m_Localized: "\u0411\u04B1\u043B \u04D9\u0440\u0435\u043A\u0435\u0442\u0442\u0456
      \u049B\u0430\u043B\u0430\u0439 \u0430\u0442\u0430\u0439\u0434\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 355496558592
    m_Localized: "\u049A\u0430\u0440\u0430\u043F\u0430\u0439\u044B\u043C \u043E\u0439\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 522962534400
    m_Localized: "\u041A\u0438\u0431\u0435\u0440\u0431\u0443\u043B\u043B\u0438\u043D\u0433 "
    m_Metadata:
      m_Items: []
  - m_Id: 681247178752
    m_Localized: "\u0414\u043E\u0441\u0442\u044B\u049B \u043A\u0435\u04A3\u0435\u0441"
    m_Metadata:
      m_Items: []
  - m_Id: 799526551552
    m_Localized: "\u0415\u0440\u043A\u0456\u043D \u043F\u0456\u043A\u0456\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 1148618473472
    m_Localized: "\u0411\u04B1\u043B \u0436\u0430\u0493\u0434\u0430\u0439\u0434\u0430
      \u049B\u0430\u043D\u0434\u0430\u0439 \u04D9\u0440\u0435\u043A\u0435\u0442 \u0436\u0430\u0441\u0430\u0443\u0493\u0430
      \u0431\u043E\u043B\u043C\u0430\u0439\u0434\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 1359738765312
    m_Localized: "\u0421\u0443\u0440\u0435\u0442\u0442\u0456 \u049B\u0430\u0439\u0442\u0430
      \u0436\u0430\u0440\u0438\u044F\u043B\u0430\u0443 "
    m_Metadata:
      m_Items: []
  - m_Id: 1489565057024
    m_Localized: "\u041F\u043E\u0441\u0442\u049B\u0430 \u0448\u0430\u0493\u044B\u043C\u0434\u0430\u043D\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 1598218502144
    m_Localized: "\u04AE\u043B\u043A\u0435\u043D \u0430\u0434\u0430\u043C\u0493\u0430
      \u0430\u0439\u0442\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 1753512607744
    m_Localized: "\u0421\u043E\u043B \u0430\u0434\u0430\u043C\u0434\u044B \u0431\u04B1\u0493\u0430\u0442\u0442\u0430\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 1845552414720
    m_Localized: "\u041C\u04B1\u043D\u0434\u0430\u0439 \u0436\u0430\u0493\u0434\u0430\u0439\u0434\u0430
      \u049B\u044B\u0437 \u049B\u0430\u043D\u0434\u0430\u0439 \u0441\u0435\u0437\u0456\u043C\u0434\u0435
      \u0431\u043E\u043B\u0430\u0434\u044B?"
    m_Metadata:
      m_Items: []
  - m_Id: 1923470000128
    m_Localized: "\u041A\u04E9\u04A3\u0456\u043B\u0434\u0456 \u0431\u043E\u043B\u0430\u0434\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 2026716987392
    m_Localized: "\u041A\u04E9\u04A3\u0456\u043B\u0456 \u0442\u04AF\u0441\u0435\u0434\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 2153791815680
    m_Localized: "\u0415\u043B\u0435\u043C\u0435\u0439 \u04E9\u0442\u0435\u0434\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 2252244713472
    m_Localized: "\u0410\u0448\u0443\u043B\u0430\u043D\u0430\u0434\u044B"
    m_Metadata:
      m_Items: []
  - m_Id: 2347782569984
    m_Localized: "\u0415\u0433\u0435\u0440 \u0441\u0435\u043D \u043C\u04B1\u043D\u0434\u0430\u0439
      \u043F\u043E\u0441\u0442\u0442\u044B \u043A\u04E9\u0440\u0441\u0435\u04A3,
      \u043D\u0435 \u0456\u0441\u0442\u0435\u0439\u0441\u0456\u04A3?"
    m_Metadata:
      m_Items: []
  - m_Id: 2430796234752
    m_Localized: "\u0411\u0430\u0441\u049B\u0430\u043B\u0430\u0440 \u0441\u0438\u044F\u049B\u0442\u044B
      \u043A\u04AF\u043B\u0456\u043F, \u043B\u0430\u0439\u043A \u0431\u0430\u0441\u0430\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 2530251571200
    m_Localized: "\u04AE\u043D\u0441\u0456\u0437 \u04E9\u0442\u0456\u043F \u043A\u0435\u0442\u0435\u043C\u0456\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 2624510164992
    m_Localized: "\u0421\u0435\u043D\u0456\u043C\u0434\u0456 \u04AF\u043B\u043A\u0435\u043D
      \u0430\u0434\u0430\u043C\u0493\u0430 \u0430\u0439\u0442\u0430\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 2804303200256
    m_Localized: "\u04D8\u0440\u0456 \u049B\u0430\u0440\u0430\u0439 \u043F\u0456\u043A\u0456\u0440
      \u0436\u0430\u0437\u0430\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 2930467864576
    m_Localized: "\u0415\u0433\u0435\u0440 \u0441\u0435\u043D \u04E9\u0437\u0456\u04A3
      \u049B\u0430\u0442\u0435 \u043F\u043E\u0441\u0442 \u0441\u0430\u043B\u0493\u0430\u043D\u044B\u04A3\u0434\u044B
      \u0442\u04AF\u0441\u0456\u043D\u0441\u0435\u04A3, \u043D\u0435 \u0456\u0441\u0442\u0435\u0443
      \u043A\u0435\u0440\u0435\u043A?"
    m_Metadata:
      m_Items: []
  - m_Id: 2985765568512
    m_Localized: "\u041F\u043E\u0441\u0442\u0442\u044B \u04E9\u0448\u0456\u0440\u0456\u043F,
      \u0436\u0430\u0441\u044B\u0440\u0430\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 3145761488896
    m_Localized: "\u04E8\u0437\u0456\u043C\u0434\u0456 \u0430\u049B\u0442\u0430\u0439\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 3271326367744
    m_Localized: "\u041A\u0435\u0448\u0456\u0440\u0456\u043C \u0441\u04B1\u0440\u0430\u043F,
      \u04E9\u0448\u0456\u0440\u0435\u043C\u0456\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 3373499613184
    m_Localized: "\u041A\u0456\u043D\u04D9\u043D\u0456 \u0431\u0430\u0441\u049B\u0430\u0493\u0430
      \u0430\u0443\u0434\u0430\u0440\u0430\u043C\u044B\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 8487518011392
    m_Localized: "\u041E\u043D\u043B\u0430\u0439\u043D\u0434\u0430\u0493\u044B \u049B\u0430\u0443\u0456\u043F\u0442\u0456
      \u0436\u04D9\u043D\u0435 \u049B\u0430\u0443\u0456\u043F\u0441\u0456\u0437 \u04D9\u0440\u0435\u043A\u0435\u0442\u0442\u0435\u0440\u0434\u0456
      \u0430\u0436\u044B\u0440\u0430\u0442\u044B\u043F, \u0442\u043E\u043F\u0442\u0430\u0441\u0442\u044B\u0440\u0430\u0439\u044B\u049B."
    m_Metadata:
      m_Items: []
  - m_Id: 9324013223936
    m_Localized: "\u04E8\u0437\u0456\u043D\u0456\u04A3 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u0434\u044B
      \u0430\u043A\u043A\u0430\u0443\u043D\u0442 \u049B\u04B1\u043F\u0438\u044F\u0441\u04E9\u0437\u0456\u043D
      \u0434\u043E\u0441\u0442\u0430\u0440\u044B\u043D\u0430 \u0430\u0439\u0442\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 9472831324160
    m_Localized: "\u0411\u0435\u0439\u0442\u0430\u043D\u044B\u0441 \u0430\u0434\u0430\u043C\u043D\u0430\u043D
      \u043A\u0435\u043B\u0433\u0435\u043D \u0441\u0456\u043B\u0442\u0435\u043C\u0435\u043D\u0456
      \u0430\u0448\u044B\u043F \u043A\u04E9\u0440\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 9531253784576
    m_Localized: "\u201CPrivacy\u201D \u0431\u04E9\u043B\u0456\u043C\u0456\u043D
      \u0442\u0435\u043A\u0441\u0435\u0440\u0456\u043F, \u04E9\u0437\u0456\u04A3\u0435
      \u0441\u0430\u0439 \u0431\u0430\u043F\u0442\u0430\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 9575142981632
    m_Localized: "\u049A\u043E\u0440\u043B\u0430\u0439\u0442\u044B\u043D \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439\u043B\u0435\u0440
      \u043C\u0435\u043D \u04D9\u0434\u0435\u043F\u0441\u0456\u0437 \u043A\u043E\u043D\u0442\u0435\u043D\u0442\u0456
      \u0431\u0430\u0440 \u0430\u043A\u043A\u0430\u0443\u043D\u0442\u0442\u0430\u0440\u0434\u044B
      \u201Creport\u201D \u0436\u0430\u0441\u0430\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 9630239358976
    m_Localized: " \u041A\u04E9\u043F\u0442\u0435\u0433\u0435\u043D \u0441\u0430\u0439\u0442\u0442\u0430\u0440\u0493\u0430
      \u04E9\u0437 \u0430\u043A\u043A\u0430\u0443\u043D\u0442\u044B\u04A3\u043C\u0435\u043D
      \u043A\u0456\u0440\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 9678322860032
    m_Localized: "\u0426\u0438\u0444\u0440\u043B\u044B\u049B \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0430\u043D\u044B
      \u049B\u043E\u043B\u0434\u0430\u043D\u0443 \u0443\u0430\u049B\u044B\u0442\u044B\u043D
      \u04E9\u0437\u0456\u04A3\u0435 \u0448\u0435\u043A\u0442\u0435\u0443 \u049B\u043E\u044E"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
