  m_TableData:
  - m_Id: 10577969152
    m_Localized: "\u04E8\u0433\u04E9\u0433\u0434\u0441\u04E9\u043D \u0436\u0438\u0448\u044D\u044D\u0433
      \u0430\u043D\u0445\u0430\u0430\u0440\u0430\u043B\u0442\u0430\u0439 \u0441\u043E\u043D\u0441\u043E\u043E\u0434,
      \u0430\u0441\u0443\u0443\u043B\u0442\u0430\u043D\u0434 \u0437\u04E9\u0432 \u0445\u0430\u0440\u0438\u0443\u043B\u0430\u0430\u0440\u0430\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 286907105280
    m_Localized: "\u042D\u043D\u044D \u04AF\u0439\u043B\u0434\u043B\u0438\u0439\u0433
      \u044E\u0443 \u0433\u044D\u0436 \u043D\u044D\u0440\u043B\u044D\u0445 \u0432\u044D?"
    m_Metadata:
      m_Items: []
  - m_Id: 355496558592
    m_Localized: "\u042D\u043D\u0433\u0438\u0439\u043D \u0442\u043E\u0433\u043B\u043E\u043E\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 522962534400
    m_Localized: "\u0426\u0430\u0445\u0438\u043C \u0434\u044D\u044D\u0440\u044D\u043B\u0445\u044D\u043B\u0442 "
    m_Metadata:
      m_Items: []
  - m_Id: 681247178752
    m_Localized: "\u041D\u04E9\u0445\u04E9\u0440\u0441\u04E9\u0433 \u0437\u04E9\u0432\u043B\u04E9\u0433\u04E9\u04E9"
    m_Metadata:
      m_Items: []
  - m_Id: 799526551552
    m_Localized: "\u0427\u04E9\u043B\u04E9\u04E9\u0442 \u04AF\u0437\u044D\u043B \u0431\u043E\u0434\u043E\u043B"
    m_Metadata:
      m_Items: []
  - m_Id: 1148618473472
    m_Localized: "\u042D\u043D\u044D \u0442\u043E\u0445\u0438\u043E\u043B\u0434\u043E\u043B\u0434
      \u044F\u043C\u0430\u0440 \u04AF\u0439\u043B\u0434\u044D\u043B \u0445\u0438\u0439\u0436
      \u0431\u043E\u043B\u043E\u0445\u0433\u04AF\u0439 \u0432\u044D?"
    m_Metadata:
      m_Items: []
  - m_Id: 1359738765312
    m_Localized: "\u0417\u0443\u0440\u0433\u0438\u0439\u0433 \u0434\u0430\u0445\u0438\u043D
      \u043D\u0438\u0439\u0442\u043B\u044D\u0445 "
    m_Metadata:
      m_Items: []
  - m_Id: 1489565057024
    m_Localized: "\u041F\u043E\u0441\u0442\u043E\u043D\u0434 \u0440\u0435\u043F\u043E\u0440\u0442
      \u0445\u0438\u0439\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 1598218502144
    m_Localized: "\u0422\u043E\u043C \u0445\u04AF\u043D\u0434 \u043C\u044D\u0434\u044D\u0433\u0434\u044D\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 1753512607744
    m_Localized: "\u0422\u0443\u0445\u0430\u0439\u043D \u0445\u04AF\u043D\u0438\u0439\u0433
      \u0431\u043B\u043E\u043A\u043B\u043E\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 1845552414720
    m_Localized: "\u0418\u0439\u043C \u043D\u04E9\u0445\u0446\u04E9\u043B\u0434 \u0442\u0443\u0445\u0430\u0439\u043D
      \u043E\u0445\u0438\u043D\u0434 \u044F\u043C\u0430\u0440 \u043C\u044D\u0434\u0440\u044D\u043C\u0436
      \u0442\u04E9\u0440\u04E9\u0445 \u0432\u044D? "
    m_Metadata:
      m_Items: []
  - m_Id: 1923470000128
    m_Localized: "\u0425\u04E9\u0433\u0436\u0438\u043B\u0442\u044D\u0439 \u0431\u0430\u0439\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 2026716987392
    m_Localized: "\u0421\u044D\u0442\u0433\u044D\u043B \u0441\u0430\u043D\u0430\u0430\u0433\u0430\u0430\u0440
      \u0443\u043D\u0430\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 2153791815680
    m_Localized: "\u0422\u043E\u043E\u0445\u0433\u04AF\u0439 \u04E9\u043D\u0433\u04E9\u0440\u04AF\u04AF\u043B\u043D\u044D."
    m_Metadata:
      m_Items: []
  - m_Id: 2252244713472
    m_Localized: "\u0423\u0443\u0440 \u043D\u044C \u0445\u04AF\u0440\u043D\u044D."
    m_Metadata:
      m_Items: []
  - m_Id: 2347782569984
    m_Localized: "\u0422\u0443\u0445\u0430\u0439\u043D \u043F\u043E\u0441\u0442\u044B\u0433
      \u0445\u0430\u0440\u0441\u0430\u043D \u0431\u043E\u043B \u0447\u0438 \u044E\u0443
      \u0445\u0438\u0439\u0445 \u0432\u044D?"
    m_Metadata:
      m_Items: []
  - m_Id: 2430796234752
    m_Localized: "\u0411\u0443\u0441\u0434\u044B\u043D \u0430\u0434\u0438\u043B \u0438\u043D\u044D\u044D\u0436,
      \u043B\u0430\u0439\u043A \u0434\u0430\u0440\u043D\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 2530251571200
    m_Localized: "\u0414\u0443\u0443\u0433\u04AF\u0439 \u04E9\u043D\u0433\u04E9\u0440\u043D\u04E9."
    m_Metadata:
      m_Items: []
  - m_Id: 2624510164992
    m_Localized: "\u0418\u0442\u0433\u044D\u043B\u0442\u044D\u0439 \u0442\u043E\u043C
      \u0445\u04AF\u043D\u0434 \u0445\u044D\u043B\u043D\u044D."
    m_Metadata:
      m_Items: []
  - m_Id: 2804303200256
    m_Localized: "\u04AE\u0440\u0433\u044D\u043B\u0436\u043B\u04AF\u04AF\u043B\u044D\u043D
      \u043A\u043E\u043C\u043C\u0435\u043D\u0442 \u0431\u0438\u0447\u043D\u044D."
    m_Metadata:
      m_Items: []
  - m_Id: 2930467864576
    m_Localized: "\u0425\u044D\u0440\u044D\u0432 \u0447\u0438 \u04E9\u04E9\u0440\u04E9\u04E9
      \u0431\u0443\u0440\u0443\u0443 \u0437\u04AF\u0439\u043B \u043F\u043E\u0441\u0442\u043E\u043B\u0441\u043E\u043D
      \u0433\u044D\u0434\u0433\u044D\u044D \u043E\u0439\u043B\u0433\u043E\u0432\u043E\u043B
      \u044F\u0430\u0445 \u0451\u0441\u0442\u043E\u0439 \u0432\u044D?"
    m_Metadata:
      m_Items: []
  - m_Id: 2985765568512
    m_Localized: "\u041F\u043E\u0441\u0442\u0442\u0443 \u04E9\u0447\u04AF\u0440\u04AF\u043F,
      \u0447\u0430\u0436\u044B\u0440\u0430\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 3145761488896
    m_Localized: "\u04E8\u04E9\u0440\u0438\u0439\u0433\u04E9\u04E9 \u04E9\u043C\u04E9\u04E9\u0440\u043D\u04E9."
    m_Metadata:
      m_Items: []
  - m_Id: 3271326367744
    m_Localized: "\u0423\u0443\u0447\u043B\u0430\u043B\u0442 \u0433\u0443\u0439\u0436,
      \u0443\u0441\u0442\u0433\u0430\u043D\u0430. "
    m_Metadata:
      m_Items: []
  - m_Id: 3373499613184
    m_Localized: "\u0411\u0443\u0441\u0434\u0430\u0434 \u0431\u0443\u0440\u0443\u0443\u0433
      \u0442\u043E\u0445\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 8487518011392
    m_Localized: "\u041E\u043D\u043B\u0430\u0439\u043D \u0434\u0430\u0445\u044C \u0430\u044E\u0443\u043B\u0442\u0430\u0439
      \u0431\u043E\u043B\u043E\u043D \u0430\u044E\u0443\u043B\u0433\u04AF\u0439 \u04AF\u0439\u043B\u0434\u043B\u0438\u0439\u0433
      \u044F\u043B\u0433\u0430\u043D \u0430\u043D\u0433\u0438\u043B\u0446\u0433\u0430\u0430\u044F. "
    m_Metadata:
      m_Items: []
  - m_Id: 9324013223936
    m_Localized: "\u04E8\u04E9\u0440\u0438\u0439\u043D \u0446\u0430\u0445\u0438\u043C
      \u0445\u0430\u044F\u0433\u0438\u0439\u043D \u043D\u0443\u0443\u0446 \u04AF\u0433\u0438\u0439\u0433
      \u043D\u0430\u0439\u0437\u0443\u0443\u0434\u0434\u0430\u0430 \u0445\u044D\u043B\u044D\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 9472831324160
    m_Localized: "\u0422\u0430\u043D\u0438\u0445\u0433\u04AF\u0439 \u0445\u04AF\u043D\u044D\u044D\u0441
      \u0438\u0440\u0441\u044D\u043D \u043B\u0438\u043D\u043A\u0438\u0439\u0433 \u043D\u044D\u044D\u0436
      \u04AF\u0437\u044D\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 9531253784576
    m_Localized: "\u201CPrivacy\u201D \u0445\u044D\u0441\u0433\u044D\u044D \u0448\u0430\u043B\u0433\u0430\u043D
      \u04E9\u04E9\u0440\u0442 \u043D\u0438\u0439\u0446\u04AF\u04AF\u043B\u044D\u043D
      \u0442\u043E\u0445\u0438\u0440\u0443\u0443\u043B\u0436 \u0431\u0430\u0439\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 9575142981632
    m_Localized: "\u0414\u043E\u0440\u043E\u043C\u0436\u0438\u043B\u0441\u043E\u043D
      \u043A\u043E\u043C\u043C\u0435\u043D\u0442 \u0431\u043E\u043B\u043E\u043D \u0451\u0441
      \u0431\u0443\u0441 \u0430\u0433\u0443\u0443\u043B\u0433\u0430\u0442\u0430\u0439
      \u0445\u0430\u044F\u0433\u0438\u0439\u0433 \u201Creport\u201D \u0445\u0438\u0439\u0436
      \u0431\u0430\u0439\u0445 "
    m_Metadata:
      m_Items: []
  - m_Id: 9630239358976
    m_Localized: "\u041C\u0430\u0448 \u043E\u043B\u043E\u043D \u0441\u0430\u0439\u0442\u0443\u0443\u0434\u0430\u0434
      \u04E9\u04E9\u0440\u0438\u0439\u043D \u0445\u0430\u044F\u0433\u0430\u0430\u0440
      \u043D\u044D\u0432\u0442\u044D\u0440\u0447 \u043E\u0440\u043E\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 9678322860032
    m_Localized: "\u0426\u0430\u0445\u0438\u043C \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C
      \u0430\u0448\u0438\u0433\u043B\u0430\u0445 \u0446\u0430\u0433\u0438\u0439\u043D
      \u043B\u0438\u043C\u0438\u0442\u0438\u0439\u0433 \u04E9\u04E9\u0440\u0442\u04E9\u04E9
      \u0442\u043E\u0445\u0438\u0440\u0443\u0443\u043B\u0430\u043D \u0442\u043E\u0433\u0442\u043E\u043E\u0445"
    m_Metadata:
      m_Items: []
